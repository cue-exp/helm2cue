Consecutive YAML key-value pairs each containing an inline
if/else should both convert correctly. The second pair must
not be discarded by collectInlineSuffix.

-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  a: x{{ if .Values.x }}1{{ else }}2{{ end }}y
  b: x{{ if .Values.x }}3{{ else }}4{{ end }}y
-- values.yaml --
x: true
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  a: x1y
  b: x3y
-- output.cue --
import "struct"

#values: {
	x?: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			if (_nonzero & {
				#arg: #values.x
			}).out {
				a: "x1y"
			}
			if !((_nonzero & {
				#arg: #values.x
			}).out) {
				a: "x2y"
			}
			if (_nonzero & {
				#arg: #values.x
			}).out {
				b: "x3y"
			}
			if !((_nonzero & {
				#arg: #values.x
			}).out) {
				b: "x4y"
			}
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
