range over list where first item is inside a conditional (if/with)
-- values.yaml --
rules:
  - name: rule1
    backendRef: svc
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
spec:
  rules:
    {{- range .Values.rules }}
    {{- if .name }}
    - name: {{ .name }}
    {{- end }}
      backendRef: {{ .backendRef }}
    {{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
spec:
  rules:
    - name: rule1
      backendRef: svc
-- output.cue --
import "struct"

#values: {
	rules?: [...{
		name!:       bool | number | string | null
		backendRef!: bool | number | string | null
		...
	}] | {
		[string]: {
			name!:       bool | number | string | null
			backendRef!: bool | number | string | null
			...
		}
	}
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		spec: rules: [
			if (_nonzero & {#arg: #values.rules}).out
			for _, _range0 in #values.rules {
				if (_nonzero & {#arg: _range0.name}).out {
					name: _range0.name
				}
				backendRef: _range0.backendRef
			},
		]
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
