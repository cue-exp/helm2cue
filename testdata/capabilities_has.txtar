.Capabilities.APIVersions.Has condition.

-- values.yaml --
name: test
-- input.yaml --
{{- if .Capabilities.APIVersions.Has "v1" }}
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .Values.name }}
data:
  key: value
{{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  key: value
-- output.cue --
import (
	"list"
	"struct"
)

#capabilities: {
	APIVersions!: _
	...
}
#values: {
	name!: bool | number | string | null
	...
}

output: [
	if list.Contains(#capabilities.APIVersions, "v1") {
		{
			apiVersion: "v1"
			kind:       "ConfigMap"
			metadata: name: "\(#values.name)"
			data: key:      "value"
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
