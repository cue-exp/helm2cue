Range with $key, $value destructuring over a map.

-- values.yaml --
labels:
  app: myapp
  env: production
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  labels:
    app: myapp
    env: production
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  labels:
    {{- range $key, $value := .Values.labels }}
    {{ $key }}: {{ $value }}
    {{- end }}
-- output.cue --
import "struct"

#values: {
	labels?: _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name: "test"
			labels: {
				if (_nonzero & {#arg: #values.labels, _}) for _key0, _val0 in #values.labels {
					(_key0): _val0
				}
			}
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
