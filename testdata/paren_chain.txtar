Parenthesized field access chain with default.

-- values.yaml --
cpu: 100m
-- input.yaml --
cpu: {{ ((.Values).cpu) | default 0 }}
-- helm_output.yaml --
cpu: 100m
-- output.cue --
import "struct"

#values: {
	...
}

output: [
	{
		cpu: [if (_nonzero & {#arg: #values.cpu}).out {
			#values.cpu
		}, 0][0]
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
