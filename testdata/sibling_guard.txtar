Guard on a sibling field should make other fields under the same parent
optional. Regression test for https://github.com/cue-exp/helm2cue/issues/81.

-- values.yaml --
name: myapp
config:
  enabled: true
  name: hello
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  name: hello
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
{{- if .Values.config.enabled }}
  name: {{ .Values.config.name }}
{{- end }}
-- output.cue --
import "struct"

#values: {
	config?: {
		enabled?: bool | number | string | null
		name?:    bool | number | string | null
		...
	}
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			if (_nonzero & {
				#arg: #values.config.enabled
				_
			}) {
				name: "\(#values.config.name)"
			}
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
