omit function inside with block: dot rebinding for parenthesized omit.

-- values.yaml --
annotations:
  enabled: true
  app: myapp
-- input.yaml --
metadata:
{{- with (omit .Values.annotations "enabled") }}
  annotations:
{{- toYaml . | nindent 4 }}
{{- end }}
-- helm_output.yaml --
metadata:
  annotations:
    app: myapp
-- output.cue --
import (
	"struct"
	"list"
)

#values: {
	annotations?: _
	...
}

output: [
	{
		metadata: {
			if (_nonzero & {#arg: (_omit & {#arg: #values.annotations, #omit: ["enabled"]}), _}) {
				annotations: (_omit & {#arg: #values.annotations, #omit: ["enabled"]})
			}
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_omit: {
	#arg!:  _
	#omit!: _

	for k, v in #arg if !list.Contains(#omit, k) {
		(k): v
	}
}
