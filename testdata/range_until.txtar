Range over until(N), producing per-replica entries.

-- values.yaml --
replicas: 3
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  {{- range $i, $e := until (int .Values.replicas) }}
  replica-{{ $i }}: "instance-{{ $e }}"
  {{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  replica-0: "instance-0"
  replica-1: "instance-1"
  replica-2: "instance-2"
-- broken --
unsupported pipe
