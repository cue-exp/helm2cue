Range over until(N), producing per-replica list items.

-- values.yaml --
replicas: 3
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  items:
  {{- range $i, $e := until (int .Values.replicas) }}
    - {{ $e }}
  {{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  items:
    - 0
    - 1
    - 2
-- output.cue --
import "list"

#values: {
	replicas?: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: items: [for _key0, _val0 in list.Range(0, int & #values.replicas, 1) {
			_val0
		},
		]
	},
]
