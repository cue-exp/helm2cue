int function piped from a default expression inside printf.
No round-trip comparison: Helm renders an integer while CUE
produces a string interpolation.

-- values.yaml --
containerPorts:
  http: 80
metrics:
  port: 9113
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  port: {{ printf "%d" (default .Values.containerPorts.http .Values.metrics.port | int) }}
-- output.cue --
import "struct"

#values: {
	containerPorts?: {
		http!: bool | number | string | null
		...
	}
	metrics?: {
		port?: bool | number | string | null
		...
	}
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: port:     "\(int & [if (_nonzero & {#arg: #values.metrics.port}).out {
			#values.metrics.port
		}, #values.containerPorts.http][0])"
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
