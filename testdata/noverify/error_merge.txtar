merge function in inline position.
No semantic comparison: CUE comprehension-based merge differs from
Go runtime map mutation.

-- values.yaml --
a:
  x: 1
b:
  y: 2
-- input.yaml --
data: {{ merge .Values.a .Values.b | toYaml | nindent 2 }}
-- output.cue --
#values: {
	a!: _
	b!: _
	...
}

output: [
	{
		data: (_merge & {#a: #values.a, #b: #values.b}).out
	},
]
_merge: {
	#a!: _
	#b!: _
	out: {
		for k, v in #a {
			(k): v
		}
		for k, v in #b if #a[k] == _|_ {
			(k): v
		}
	}
}
