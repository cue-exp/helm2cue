kindIs condition: check Go reflect.Kind of a value.
No semantic comparison: CUE type unification differs from Go runtime kind checks.

-- values.yaml --
config:
  key: value
-- input.yaml --
{{- if kindIs "bool" .Values.config }}
boolVal: true
{{- else if kindIs "map" .Values.config }}
mapVal: true
{{- end }}
-- output.cue --
import "struct"

#values: {
	config!: bool | number | string | null
	...
}

output: [
	{
		if (#values.config & bool) != _|_ {
			boolVal: true
		}
		if !((#values.config & bool) != _|_) if (#values.config & {...}) != _|_ {
			mapVal: true
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
