Default value referencing non-values context object.
Round-trip Helm comparison not possible because the CUE output
references #chart which requires concrete values from Chart.yaml
(only available in chart-level conversion).

-- values.yaml --
nameOverride: ""
-- input.yaml --
name: {{ default .Chart.Name .Values.nameOverride }}
-- output.cue --
import "struct"

#chart: {
	Name!: bool | number | string | null
	...
}
#values: {
	nameOverride?: bool | number | string | null
	...
}

output: [
	{
		name: [if (_nonzero & {#arg: #values.nameOverride}).out {
			#values.nameOverride
		}, #chart.Name][0]
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
