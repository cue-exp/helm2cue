typeOf condition: check Go type name of a value.
No semantic comparison: CUE type unification differs from Go runtime type names.

-- values.yaml --
config: some-string
-- input.yaml --
{{- if eq (typeOf .Values.config) "string" }}
stringVal: true
{{- else }}
otherVal: true
{{- end }}
-- error --
unsupported condition function: typeOf
