String splitList function.
No semantic comparison: Helm renders Go slice format [a b c] while CUE
produces a proper list.

-- values.yaml --
csv: "a,b,c"
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  items: {{ .Values.csv | splitList "," }}
-- output.cue --
import "strings"

#values: {
	csv!: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: items:    strings.Split(#values.csv, ",")
	},
]
