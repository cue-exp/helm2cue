typeIs condition: check Go type name of a value.
No semantic comparison: CUE type unification differs from Go runtime type checks.

-- values.yaml --
config:
  key: value
-- input.yaml --
{{- if typeIs "string" .Values.config }}
stringVal: true
{{- else if typeIs "map[string]interface {}" .Values.config }}
mapVal: true
{{- end }}
-- output.cue --
import "struct"

#values: {
	config!: bool | number | string | null
	...
}

output: [
	{
		if (#values.config & string) != _|_ {
			stringVal: true
		}
		if !((#values.config & string) != _|_) if (#values.config & {
			...
		}) != _|_ {
			mapVal: true
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
