Value reference inside an if-guard for the same field should be optional.

-- values.yaml --
name: myapp
x: hello
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
{{- if .Values.x }}
  key: {{ .Values.x }}
{{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  key: hello
-- output.cue --
import "struct"

#values: {
	x?: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			if (_nonzero & {
				#arg: #values.x
				_
			}) {
				key: "\(#values.x)"
			}
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
