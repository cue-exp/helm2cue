Range over a list.

-- input.yaml --
items:
{{- range .input.items }}
  - {{ . }}
{{- end }}
-- values.yaml --
items:
  - a
  - b
  - c
-- output.cue --
import "struct"

#input: {
	items?: [...] | {
		...
	}
	...
}

output: [
	{
		items: [if (_nonzero & {#arg: #input.items}).out for _, _range0 in #input.items {
			_range0
		},
		]
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
