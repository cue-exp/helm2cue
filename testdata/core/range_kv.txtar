Range over a map with key-value variables.

-- input.yaml --
labels:
{{- range $k, $v := .input.labels }}
  {{ $k }}: {{ $v }}
{{- end }}
-- values.yaml --
labels:
  app: myapp
  env: prod
-- output.cue --
import "struct"

#input: {
	labels?: [...] | {
		...
	}
	...
}

output: [
	{
		labels: {
			if (_nonzero & {#arg: #input.labels}).out for _key0, _val0 in #input.labels {
				(_key0): _val0
			}
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
