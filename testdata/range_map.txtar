Range target accessed via a variable should infer the correct schema
field, allowing both list and map types.

-- values.yaml --
server:
  enabled: true
  paths:
    - /foo
    - /bar
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  paths:
    - /foo
    - /bar
-- input.yaml --
{{- if .Values.server.enabled -}}
{{- $srv := .Values.server -}}
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  paths:
    {{- range $p := $srv.paths }}
    - {{ $p }}
    {{- end }}
{{- end }}
-- output.cue --
import "struct"

#values: {
	server?: {
		enabled?: bool | number | string | null
		paths?: [...] | {
			...
		}
		...
	}
	...
}

output: [
	if (_nonzero & {#arg: #values.server.enabled}).out {
		{
			apiVersion: "v1"
			kind:       "ConfigMap"
			metadata: name: "test"
			data: paths: [
				if (_nonzero & {#arg: #values.server.paths}).out
				for _, _range0 in #values.server.paths {
					_range0
				},
			]
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
