default with list and dict literals as default values.

-- values.yaml --
items:
  - one
  - two
labels: {}
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  items: {{ default (list) .Values.items | toJson }}
  bare: {{ default list .Values.items | toJson }}
  labels: {{ default (dict) .Values.labels | toJson }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  items: ["one","two"]
  bare: ["one","two"]
  labels: {}
-- output.cue --
import "struct"

#values: {
	items?:  _
	labels?: _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			items: [if (_nonzero & {
				#arg: #values.items
			}).out {
				#values.items
			}, []][0]
			bare: [if (_nonzero & {
				#arg: #values.items
			}).out {
				#values.items
			}, []][0]
			labels: [if (_nonzero & {
				#arg: #values.labels
			}).out {
				#values.labels
			}, {}][0]
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
