Range over a pipeline function call (e.g. mustUniq) should be
supported. pipeToFieldExpr must delegate to the pipeline function
conversion machinery, not reject multi-command pipes.

-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  namespaces:
{{- range $ns := mustUniq .Values.denyNamespaces }}
    - {{ $ns }}
{{- end }}
-- values.yaml --
denyNamespaces:
  - kube-system
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  namespaces:
    - kube-system
-- output.cue --
import (
	"struct"
	"list"
)

#values: {
	denyNamespaces?: _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: namespaces: [if (_nonzero & {#arg: (_uniq & {#in: #values.denyNamespaces}).out, _}) for _, _range0 in (_uniq & {#in: #values.denyNamespaces}).out {
			_range0
		},
		]
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_uniq: {
	#in: [...]
	out: [for i, x in #in if !list.Contains(list.Slice(#in, 0, i), x) {x}]
}
