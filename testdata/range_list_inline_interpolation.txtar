Range list item with inline interpolation in key-value pair.

-- values.yaml --
replicas: 2
-- input.yaml --
items:
{{ range $i, $e := until (.Values.replicas | int) }}
  - spec:
      rules:
        - host: host-{{ $i }}.example.com
          http:
            paths:
              - path: /foo
{{- end -}}
-- helm_output.yaml --
items:

  - spec:
      rules:
        - host: host-0.example.com
          http:
            paths:
              - path: /foo
  - spec:
      rules:
        - host: host-1.example.com
          http:
            paths:
              - path: /foo
-- output.cue --
import "list"

#values: {
	replicas?: bool | number | string | null
	...
}

output: [
	{
		items: [
			for _key0, _val0 in list.Range(0, int & #values.replicas, 1) {
				spec: rules: [
					{
						host: "host-\(_key0).example.com"
						http: paths: [
							{
								path: "/foo"
							},
						]
					},
				]
			},
		]
	},
]
