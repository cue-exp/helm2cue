deepCopy is a no-op in CUE (values are immutable).

-- values.yaml --
annotations:
  app: test
extra:
  env: prod
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  {{- with mergeOverwrite (deepCopy .Values.annotations) .Values.extra }}
  annotations:
    {{- toYaml . | nindent 4 }}
  {{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  annotations:
    app: test
    env: prod
-- output.cue --
import "struct"

#values: {
	annotations!: _
	extra!:       _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name: "test"
			if (_nonzero & {#arg: (_mergeOverwrite & {#a: #values.annotations, #b: #values.extra}).out}).out {
				annotations: (_mergeOverwrite & {#a: #values.annotations, #b: #values.extra}).out
			}
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_mergeOverwrite: {
	#a!: _
	#b!: _
	out: {
		for k, v in #a if #b[k] == _|_ {
			(k): v
		}
		for k, v in #b {
			(k): v
		}
	}
}
