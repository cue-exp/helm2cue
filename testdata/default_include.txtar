default with include call as default value argument.

-- _helpers.tpl --
{{- define "myapp.namespace" -}}
default-ns
{{- end -}}

-- values.yaml --
{}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  namespace: default-ns
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  namespace: {{ default (include "myapp.namespace" .) .Values.namespace }}
-- output.cue --
import "struct"

#values: {
	namespace?: bool | number | string | null
	...
}
_myapp_namespace: "default-ns"

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: namespace: [if (_nonzero & {
			#arg: #values.namespace
			_
		}) {
			#values.namespace
		}, _myapp_namespace][0]
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
