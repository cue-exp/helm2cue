omit function: return a dict with specified keys removed.

-- values.yaml --
pdb:
  enabled: true
  minAvailable: 1
-- input.yaml --
spec:
{{- toYaml (omit .Values.pdb "enabled") | nindent 2 }}
-- helm_output.yaml --
spec:
  minAvailable: 1
-- output.cue --
import "list"

#values: {
	pdb!: _
	...
}

output: [
	{
		spec: (_omit & {
			#arg: #values.pdb
			#omit: ["enabled"]
		})
	},
]
_omit: {
	#arg!:  _
	#omit!: _

	for k, v in #arg if !list.Contains(#omit, k) {
		(k): v
	}
}
