Pipeline with default value when field is null.

-- values.yaml --
name: null
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .Values.name | default "fallback" }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: fallback
-- output.cue --
import "struct"

#values: {
	name?: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: [if (_nonzero & {
			#arg: #values.name
			_
		}) {
			#values.name
		}, "fallback"][0]
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
