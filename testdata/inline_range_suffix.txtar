Two inline range blocks on the same YAML line should both be
collected into the enclosing string interpolation.

-- _helpers.tpl --
-- values.yaml --
labels:
  - a
  - b
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  expr: x{{ range .Values.labels }}{{ . }},{{ end }}y{{ range .Values.labels }}{{ . }},{{ end }}z
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  expr: xa,b,ya,b,z
-- output.cue --
import "strings"

#values: {
	labels?: _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: expr:     "x\(strings.Join([for _, _range0 in #values.labels {
			"\(_range0),"
		}], ""))y\(strings.Join([for _, _range0 in #values.labels {
			"\(_range0),"
		}], ""))z"
	},
]
