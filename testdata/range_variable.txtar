Range over a local variable assigned from .Values.

-- values.yaml --
items:
  - alpha
  - beta
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  {{- $items := .Values.items }}
  items:
    {{- range $items }}
    - {{ . }}
    {{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  items:
    - alpha
    - beta
-- output.cue --
import "struct"

#values: {
	items!: _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: items: [if (_nonzero & {
			#arg: #values.items
			_
		}) for _, _range0 in #values.items {
			_range0
		},
		]
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
