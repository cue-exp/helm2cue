# Multi-line YAML quoted string continuation lines are emitted
# as bare struct embeddings instead of a single CUE string value.
# https://github.com/cue-exp/helm2cue/issues/102
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/rules.cue expected/rules.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
url: https://example.com
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/rules.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: rules
data:
  annotations:
    description: 'Errors encountered while the config-reloader
      attempts to sync config in the namespace.

      As a result, configuration may be stale.'
    runbook_url: {{ .Values.url }}/runbook
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/rules.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

rules: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "rules"
		data: annotations: {
			description: "'Errors encountered while the config-reloader", "attempts to sync config in the namespace.", "As a result, configuration may be stale.'"
			runbook_url: "\(#values.url)/runbook"
		}
	},
]
