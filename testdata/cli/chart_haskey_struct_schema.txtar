# hasKey should not cause a field with children to be typed as a list.
# The schema should use struct wrapping, not list wrapping.
# https://github.com/cue-exp/helm2cue/issues/54

exec helm2cue chart chartdir outdir
stderr 'converted 2/2 templates'
cmp outdir/values.cue expected/values.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
secret: {}
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
{{- if .Values.secret }}
data:
  name: {{ .Values.secret.name }}
  key: {{ .Values.secret.key }}
  {{- if hasKey .Values.secret "optional" }}
  optional: {{ .Values.secret.optional }}
  {{- end }}
{{- end }}
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

#values: {
	secret!: {
		name!:     bool | number | string | null
		key!:      bool | number | string | null
		optional!: bool | number | string | null
		...
	}
	...
}
