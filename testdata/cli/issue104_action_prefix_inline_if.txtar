# Action-prefixed inline {{ if }} conditional suffix breaks scope.
# The {{ .Values.name }} action value is emitted standalone, and
# the {{ if }}-webhook{{ end }} suffix plus subsequent fields
# break out of the struct scope.
# https://github.com/cue-exp/helm2cue/issues/104
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/webhook.cue expected/webhook.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
name: my-service
deployWebhook: true
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/webhook.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  service:
    name: {{ .Values.name }}{{ if .Values.deployWebhook }}-webhook{{ end }}
    path: /validate
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/webhook.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

webhook: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: service: name: #values.name
		if (_nonzero & {
			#arg: #values.deployWebhook
		}).out {
			"-webhook"
		}
		path: "/validate"
	},
]
