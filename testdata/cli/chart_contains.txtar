# contains condition function should be supported.
# https://github.com/cue-exp/helm2cue/issues/46

exec helm2cue chart chartdir outdir
stderr 'converted 2/2 templates'
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
hostname: "example.com"
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  {{- if contains "example" .Values.hostname }}
  matched: "yes"
  {{- end }}
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

test: [{
	apiVersion: "v1"
	kind:       "ConfigMap"
	metadata: name: "test"
	data: {
		if strings.Contains(#values.hostname, "example") {
			matched: "yes"
		}
	}
}]
