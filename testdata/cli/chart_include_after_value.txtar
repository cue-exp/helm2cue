# Include after value: {{- include ... | nindent N }} after a
# value line should emit the include as a standalone struct
# embedding, not merge it into the preceding interpolation.
# https://github.com/cue-exp/helm2cue/issues/52
exec helm2cue chart chartdir outdir
stderr 'converted 2/2 templates'
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
name: myapp
-- chartdir/templates/_helpers.tpl --
{{- define "test.name" -}}
{{ .Values.name }}
{{- end -}}

{{- define "test.labels" -}}
chart: test-app
{{- end -}}
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  labels:
    app: {{ template "test.name" . }}-alertmanager
    {{- include "test.labels" . | nindent 4 }}
data:
  key: value
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name: "test"
			labels: {
				app: "\(_test_name)-alertmanager", _test_labels
			}
		}
		data: key: "value"
	},
]
