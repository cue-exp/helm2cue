# Ternary result assigned to a variable via eq pipe should
# be supported.
# https://github.com/cue-exp/helm2cue/issues/118

exec helm template test chartdir
cmp stdout helm-stdout.golden

# The converter currently rejects eq in action pipe position.
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
server:
  insecure: "true"
  service:
    servicePortHttp: 80
    servicePortHttps: 443
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
{{- $insecure := .Values.server.insecure }}
{{- $servicePort := eq $insecure "true" | ternary .Values.server.service.servicePortHttp .Values.server.service.servicePortHttps }}
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
    - port: {{ $servicePort }}
-- helm-stdout.golden --
---
# Source: test-app/templates/good.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
---
# Source: test-app/templates/test.yaml
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
    - port: 80
-- stderr.golden --
warning: skipping test.yaml (doc 0): unsupported template action: {{$servicePort := eq $insecure "true" | ternary .Values.server.service.servicePortHttp .Values.server.service.servicePortHttps}}
converted 1/2 templates from test-app
