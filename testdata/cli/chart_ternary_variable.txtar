# Ternary result assigned to a variable via eq pipe should
# be supported.
# https://github.com/cue-exp/helm2cue/issues/118

exec helm template test chartdir
cmp stdout helm-stdout.golden

exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

# Round-trip: cue export should match helm output.
cd outdir
exec cue export --out yaml -e 'yaml.MarshalStream(results)' --out text .
cmp stdout ../cue-stdout.golden

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
server:
  insecure: "true"
  service:
    servicePortHttp: 80
    servicePortHttps: 443
-- chartdir/templates/test.yaml --
{{- $insecure := .Values.server.insecure }}
{{- $servicePort := eq $insecure "true" | ternary .Values.server.service.servicePortHttp .Values.server.service.servicePortHttps }}
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
    - port: {{ $servicePort }}
-- helm-stdout.golden --
---
# Source: test-app/templates/test.yaml
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
    - port: 80
-- stderr.golden --
converted 1/1 templates from test-app
-- cue-stdout.golden --
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
    - port: 80

-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "Service"
		metadata: name: "test"
		spec: ports: [
			{
				port: [if (_nonzero & {#arg: #values.server.insecure == "true"}).out {
					#values.server.service.servicePortHttp
				}, #values.server.service.servicePortHttps][0]
			},
		]
	},
]
