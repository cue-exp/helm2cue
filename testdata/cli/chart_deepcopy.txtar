# deepCopy in a mergeOverwrite argument should be treated as a
# no-op since CUE values are immutable.
# https://github.com/cue-exp/helm2cue/issues/116

# Helm renders the merged annotations correctly.
exec helm template test chartdir
cmp stdout helm-stdout.golden

# The converter should handle deepCopy as identity.
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

# Round-trip: cue export should match helm output.
cd outdir
exec cue export --out yaml -e 'yaml.MarshalStream(results)' --out text .
cmp stdout ../cue-stdout.golden

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
annotations:
  app: test
extra:
  env: prod
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  {{- with mergeOverwrite (deepCopy .Values.annotations) .Values.extra }}
  annotations:
    {{- toYaml . | nindent 4 }}
  {{- end }}
-- helm-stdout.golden --
---
# Source: test-app/templates/good.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
---
# Source: test-app/templates/test.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  annotations:
    app: test
    env: prod
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name: "test"
			if (_nonzero & {#arg: (_mergeOverwrite & {#a: #values.annotations, #b: #values.extra}).out}).out {
				annotations: (_mergeOverwrite & {#a: #values.annotations, #b: #values.extra}).out
			}
		}
	},
]
-- cue-stdout.golden --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  annotations:
    app: test
    env: prod

