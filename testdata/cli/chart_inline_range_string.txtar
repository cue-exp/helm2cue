# Inline range within a string value should stay inline.
# https://github.com/cue-exp/helm2cue/issues/62

# Helm renders the range inline within the string.
exec helm template test chartdir
cmp stdout helm-stdout

# The converter keeps the range inline using strings.Join.
exec helm2cue chart chartdir outdir
cmp outdir/test.cue expected/test.cue
cd outdir
exec cue export --out yaml -e 'yaml.MarshalStream(results)' --out text .
cmp stdout ../cue-stdout

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
labels:
  - foo
  - bar
-- chartdir/templates/test.yaml --
data:
  expr: count(up) BY ({{ range .Values.labels }}{{ . }},{{ end }}cluster)
-- helm-stdout --
---
# Source: test-app/templates/test.yaml
data:
  expr: count(up) BY (foo,bar,cluster)
-- cue-stdout --
data:
  expr: count(up) BY (foo,bar,cluster)

-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

test: [{
	data: {
		expr: "count(up) BY (\(strings.Join([for _, _range0 in #values.labels {"\(_range0),"}], ""))cluster)"
	}
}]
