# Subchart helper .Values refs should not pollute the parent chart's
# inferred schema. The mylib subchart defines a helper that accesses
# .Values.appName, but the parent chart never includes that helper.
# https://github.com/cue-exp/helm2cue/issues/83
! exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/values.cue expected/values.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: parent-app
version: 0.1.0
dependencies:
  - name: mylib
    version: 0.1.0
-- chartdir/values.yaml --
name: myapp
-- chartdir/templates/deploy.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  key: {{ .Values.name }}
-- chartdir/charts/mylib/Chart.yaml --
apiVersion: v2
name: mylib
version: 0.1.0
-- chartdir/charts/mylib/templates/_helpers.tpl --
{{- define "mylib.labels" -}}
app: {{ .Values.appName }}
{{- end -}}
-- stderr.golden --
error: values.yaml does not satisfy inferred schema: #values.appName: field is required but not present
converted 1/1 templates from parent-app
helm2cue: values schema validation failed
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package parent_app

#values: {
	appName!: bool | number | string | null
	name!:    bool | number | string | null
	...
}
