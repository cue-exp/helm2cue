# Two inline range blocks on the same YAML line should both
# be collected into the enclosing string interpolation.
# https://github.com/cue-exp/helm2cue/issues/72
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
labels:
  - a
  - b
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  expr: x{{ range .Values.labels }}{{ . }},{{ end }}y{{ range .Values.labels }}{{ . }},{{ end }}z
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: expr:     "x\(strings.Join([for _, _range0 in #values.labels {"\(_range0),"}], ""))y\(strings.Join([for _, _range0 in #values.labels {"\(_range0),"}], ""))z"
	},
]
