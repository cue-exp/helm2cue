# Multi-line text helper (no YAML structure) produces conflicting
# struct embeddings instead of a string value.
# https://github.com/cue-exp/helm2cue/issues/85
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/helpers.cue expected/helpers.cue
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
name: myapp
namespace: default
-- input/templates/_helpers.tpl --
{{- define "test.names" }}
{{- .Values.name }}
{{ .Values.name }}.{{ .Values.namespace }}.svc
{{- end }}
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  names: |
    {{ include "test.names" . | trim | nindent 4 }}
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/helpers.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

_test_names: {
	#values.name
	#values.name
	".\(#values.namespace).svc"
}
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: names:    strings.TrimSpace(_test_names)
	},
]
