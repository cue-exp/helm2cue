# Range accumulator pattern (append in loop) produces out-of-scope
# _range reference. The converter should emit a list comprehension.
exec helm2cue chart chartdir outdir
stderr 'converted 1/1 templates'
cmp outdir/test.cue expected/test.cue

# cue export fails because _range0 is referenced outside its scope:
cd outdir
! exec cue export --out yaml -t release_name=test .
cmp stderr ../stderr.golden

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
items:
  - alpha
  - beta
  - gamma
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  {{- $acc := list }}
  {{- range $item := .Values.items }}
  {{- $acc = append $acc $item }}
  {{- end }}
  result: {{ $acc | join "," }}
-- stderr.golden --
test.data.result: reference "_range0" not found:
    ./test.cue:17:25
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			if (_nonzero & {
				#arg: #values.items
				_
			}) for _, _range0 in #values.items {}
			result: strings.Join(_range0+[[]], ",")
		}
	},
]
