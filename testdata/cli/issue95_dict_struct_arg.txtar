# dict arg typed as scalar for struct value when accessed via
# parenthesized safe-navigation pattern ((.global).imageRegistry).
# https://github.com/cue-exp/helm2cue/issues/95
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/helpers.cue expected/helpers.cue
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
global:
  imageRegistry: ""
  imagePullSecrets: []
image:
  registry: docker.io
  repository: nginx
-- input/templates/_helpers.tpl --
{{- define "test.image" -}}
{{- $reg := default .imageRoot.registry ((.global).imageRegistry) -}}
{{- printf "%s/%s" $reg .imageRoot.repository -}}
{{- end -}}
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  img: {{ include "test.image" (dict "imageRoot" .Values.image "global" .Values.global) }}
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/helpers.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "struct"

// _nonzero tests whether a value is "truthy" (non-zero,
// non-empty, non-null), matching Go text/template semantics.
// A natural candidate for a CUE standard library builtin.
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_test_image: {
	#arg: {
		imageRoot?: {
			registry!:   bool | number | string | null
			repository!: bool | number | string | null
			...
		}
		global?: {
			imageRegistry?: bool | number | string | null
			...
		}
		...
	}
	"\([if (_nonzero & {
		#arg: #arg.global.imageRegistry
	}).out {
		#arg.global.imageRegistry
	}, #arg.imageRoot.registry][0])/\(#arg.imageRoot.repository)"
}
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: img: _test_image & {
			#arg: {imageRoot: #values.image, global: #values.global}
			_
		}
	},
]
