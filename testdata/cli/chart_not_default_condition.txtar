# Multi-command condition with not and default should be
# supported. Also tests with pipe with default.
# https://github.com/cue-exp/helm2cue/issues/120

exec helm template test chartdir
cmp stdout helm-stdout.golden

exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
controller:
  dynamicClusterDistribution: false
  runtimeClassName: ""
-- chartdir/templates/test.yaml --
{{- if not .Values.controller.dynamicClusterDistribution | default false }}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: test
spec:
  replicas: 1
  template:
    spec:
      {{- with .Values.controller.runtimeClassName | default "" }}
      runtimeClassName: {{ . }}
      {{- end }}
      containers:
        - name: main
          image: test:latest
{{- end }}
-- helm-stdout.golden --
---
# Source: test-app/templates/test.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: test
spec:
  replicas: 1
  template:
    spec:
      containers:
        - name: main
          image: test:latest
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	if (_nonzero & {#arg: [if (_nonzero & {#arg: !((_nonzero & {#arg: #values.controller.dynamicClusterDistribution}).out)}).out {
		!((_nonzero & {#arg: #values.controller.dynamicClusterDistribution}).out)
	}, false][0]}).out {
		{
			apiVersion: "apps/v1"
			kind:       "Deployment"
			metadata: name: "test"
			spec: {
				replicas: 1
				template: spec: {
					if (_nonzero & {#arg: [if (_nonzero & {#arg: #values.controller.runtimeClassName}).out {
						#values.controller.runtimeClassName
					}, ""][0]}).out {
						runtimeClassName: [if (_nonzero & {#arg: #values.controller.runtimeClassName}).out {
							#values.controller.runtimeClassName
						}, ""][0]
					}
					containers: [
						{
							name:  "main"
							image: "test:latest"
						},
					]
				}
			}
		}
	},
]
