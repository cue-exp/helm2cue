# Guard condition on a sibling field should make other fields under the
# same parent optional. Regression test for
# https://github.com/cue-exp/helm2cue/issues/81 (B).
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/deploy.cue expected/deploy.cue
cmp outdir/values.cue expected/values.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
name: myapp
-- chartdir/templates/deploy.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
{{- if .Values.config.enabled }}
  name: {{ .Values.config.name }}
{{- end }}
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/deploy.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

deploy: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			if (_nonzero & {#arg: #values.config.enabled}).out {
				name: #values.config.name
			}
		}
	},
]
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

#values: {
	config?: {
		enabled?: bool | number | string | null
		name?:    bool | number | string | null
		...
	}
	...
}
