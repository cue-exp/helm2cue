# Range over list where the first item is conditional (inside with)
# should still produce a for comprehension.
# https://github.com/cue-exp/helm2cue/issues/123

exec helm template test chartdir
cmp stdout helm-stdout.golden

exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
rules:
  - name: rule1
    backendRef: svc
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
spec:
  rules:
    {{- range .Values.rules }}
    {{- with .name }}
    - name: {{ . }}
    {{- end }}
      backendRef: {{ .backendRef }}
    {{- end }}
-- helm-stdout.golden --
---
# Source: test-app/templates/good.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
---
# Source: test-app/templates/test.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
spec:
  rules:
    - name: rule1
      backendRef: svc
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		spec: {
			rules: {}
			if (_nonzero & {#arg: _range0.name}).out {}
			backendRef: _range0.backendRef
		}
	},
]
