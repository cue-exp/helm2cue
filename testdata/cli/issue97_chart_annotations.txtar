# .Chart.Annotations emits wrong case (Annotations instead of annotations).
# https://github.com/cue-exp/helm2cue/issues/97
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
{}
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  fips: {{ .Chart.Annotations.fips }}
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: fips:     #chart.Annotations.fips
	},
]
