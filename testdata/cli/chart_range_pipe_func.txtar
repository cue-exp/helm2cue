# Range over a pipeline function call (e.g. mustUniq) should be
# supported. pipeToFieldExpr must delegate to the pipeline function
# conversion machinery, not reject multi-command pipes.
# https://github.com/cue-exp/helm2cue/issues/71
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
denyNamespaces:
  - kube-system
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  namespaces:
{{- range $ns := mustUniq .Values.denyNamespaces }}
    - {{ $ns }}
{{- end }}
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: namespaces: [if (_nonzero & {
			#arg: (_uniq & {
				#in: #values.denyNamespaces
			}).out
		}).out for _, _range0 in (_uniq & {
			#in: #values.denyNamespaces
		}).out {
			_range0
		},
		]
	},
]
