# Parenthesized and/or args produce PipeNode which collectGuardedPaths
# did not handle. Regression test for
# https://github.com/cue-exp/helm2cue/issues/81 (A2).
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/deploy.cue expected/deploy.cue
cmp outdir/values.cue expected/values.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
name: myapp
-- chartdir/templates/deploy.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
{{- if and (.Values.x) (.Values.y) }}
  key: {{ .Values.y }}
{{- end }}
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/deploy.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

deploy: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: {
			if (_nonzero & {
				#arg: #values.x
				_
			}) && (_nonzero & {
				#arg: #values.y
				_
			}) {
				key: #values.y
			}
		}
	},
]
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

#values: {
	x?: bool | number | string | null
	y?: bool | number | string | null
	...
}
