# with blocks act as guards but did not suppress required for fields
# accessed inside the body. Regression test for
# https://github.com/cue-exp/helm2cue/issues/81 (A4).
! exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/deploy.cue expected/deploy.cue
cmp outdir/values.cue expected/values.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
name: myapp
-- chartdir/templates/_helpers.tpl --
{{- define "test.limits" -}}
{{- with .sampleLimit }}
sampleLimit: {{ . }}
{{- end }}
{{- with .targetLimit }}
targetLimit: {{ . }}
{{- end }}
{{- end -}}
-- chartdir/templates/deploy.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
spec:
  {{- include "test.limits" .Values.monitor | nindent 2 }}
-- stderr.golden --
error: values.yaml does not satisfy inferred schema: #values.monitor: field is required but not present
converted 1/1 templates from test-app
helm2cue: values schema validation failed
-- expected/deploy.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

deploy: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		spec: _test_limits & {
			#arg: #values.monitor
			_
		}
	},
]
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

#values: {
	monitor!: {
		sampleLimit!: bool | number | string | null
		targetLimit!: bool | number | string | null
		...
	}
	...
}
