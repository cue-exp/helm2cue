# Nested range with same variable name ($i) should not panic
# when the inner range deletes the variable from localVars.

# Helm renders the nested ranges correctly.
exec helm template test chartdir
cmp stdout helm-stdout.golden

# The converter should not panic.
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

# Round-trip: cue export fails because the helper struct conversion
# produces conflicting values for the nested range output.
# https://github.com/cue-exp/helm2cue/issues/114
cd outdir
! exec cue export --out yaml -e 'yaml.MarshalStream(results)' --out text .
cmp stderr ../cue-stderr.golden

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
replicas: 3
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  config: |
    {{ include "test.helper" . | nindent 4 }}
-- chartdir/templates/_helpers.tpl --
{{- define "test.helper" -}}
{{- $n := int .Values.replicas -}}
{{- range $i := until $n }}
item {{ $i }}
  {{- range $i := until $n }}
  sub {{ $i }}
  {{- end }}
{{- end }}
{{- end -}}
-- helm-stdout.golden --
---
# Source: test-app/templates/good.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
---
# Source: test-app/templates/test.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  config: |
    
    
    item 0
      sub 0
      sub 1
      sub 2
    item 1
      sub 0
      sub 1
      sub 2
    item 2
      sub 0
      sub 1
      sub 2
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: config:   _test_helper
	},
]
-- cue-stderr.golden --
_test_helper: conflicting values "item1" and "item0":
    ./helpers.cue:7:15
    ./helpers.cue:8:2
    ./helpers.cue:9:3
_test_helper: conflicting values "item2" and "item0":
    ./helpers.cue:7:15
    ./helpers.cue:8:2
    ./helpers.cue:9:3
_test_helper: conflicting values "sub0" and "item0":
    ./helpers.cue:7:15
    ./helpers.cue:8:2
    ./helpers.cue:9:3
    ./helpers.cue:10:3
    ./helpers.cue:11:4
_test_helper: conflicting values "sub1" and "item0":
    ./helpers.cue:7:15
    ./helpers.cue:8:2
    ./helpers.cue:9:3
    ./helpers.cue:10:3
    ./helpers.cue:11:4
_test_helper: conflicting values "sub2" and "item0":
    ./helpers.cue:7:15
    ./helpers.cue:8:2
    ./helpers.cue:9:3
    ./helpers.cue:10:3
    ./helpers.cue:11:4
results: error in call to list.FlattenN: conflicting values "item1" and "item0":
    ./results.cue:7:10
    ./helpers.cue:7:15
    ./helpers.cue:8:2
    ./helpers.cue:9:3
