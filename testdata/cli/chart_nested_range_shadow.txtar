# Nested range with same variable name ($i) in a text helper should
# produce a string expression using strings.Join, not a struct with
# conflicting values.
# https://github.com/cue-exp/helm2cue/issues/114

# Helm renders the nested ranges correctly.
exec helm template test chartdir
cmp stdout helm-stdout.golden

# The converter should produce a scalar helper.
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue
cmp outdir/helpers.cue expected/helpers.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
replicas: 3
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  config: |
    {{ include "test.helper" . | nindent 4 }}
-- chartdir/templates/_helpers.tpl --
{{- define "test.helper" -}}
{{- $n := int .Values.replicas -}}
{{- range $i := until $n }}
item {{ $i }}
  {{- range $i := until $n }}
  sub {{ $i }}
  {{- end }}
{{- end }}
{{- end -}}
-- helm-stdout.golden --
---
# Source: test-app/templates/good.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
---
# Source: test-app/templates/test.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  config: |
    
    
    item 0
      sub 0
      sub 1
      sub 2
    item 1
      sub 0
      sub 1
      sub 2
    item 2
      sub 0
      sub 1
      sub 2
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: config:   _test_helper
	},
]
-- expected/helpers.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import (
	"strings"
	"list"
)

_test_helper: strings.TrimSpace("\(strings.Join([for _, _range1 in list.Range(0, int & #values.replicas, 1) {
	"\nitem \(_range1)\(strings.Join([for _, _range2 in list.Range(0, int & #values.replicas, 1) {
		"\n  sub \(_range2)"
	}], ""))"
}], ""))")
