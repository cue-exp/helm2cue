# Multiple YAML list items inside a conditional block should each
# get their own conditional guard in CUE. Without this, CUE sees
# multiple values at the same list position and reports a conflict.
# https://github.com/cue-exp/helm2cue/issues/77
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/test.cue expected/test.cue

-- input/Chart.yaml --
apiVersion: v2
name: test
version: 0.1.0
-- input/values.yaml --
tls: true
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/test.yaml --
apiVersion: v1
kind: Pod
metadata:
  name: test
spec:
  containers:
  - name: test
    args:
    {{- if .Values.tls }}
      - a
      - b
    {{- end }}
-- stderr.golden --
converted 2/2 templates from test
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test

test: [
	{
		apiVersion: "v1"
		kind:       "Pod"
		metadata: name: "test"
		spec: containers: [
			{
				name: "test"
				args: [if (_nonzero & {
					#arg: #values.tls
					_
				}) {
					"a"
				}, if (_nonzero & {
					#arg: #values.tls
					_
				}) {
					"b"
				},
				]
			},
		]
	},
]
