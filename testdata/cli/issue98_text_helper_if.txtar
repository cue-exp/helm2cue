# Text helper with if/range emits struct instead of string when
# the mixed content is inside a non-top-level if comprehension.
# https://github.com/cue-exp/helm2cue/issues/98
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/helpers.cue expected/helpers.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
resources: {}
-- input/templates/_helpers.tpl --
{{- define "test.warnings" -}}
{{- $msg := false -}}
{{- if not .Values.resources -}}
  {{- $msg = true -}}
{{- end -}}
{{- if $msg }}
WARNING: There are sections not set.
+info https://example.com
{{- end -}}
{{- end -}}
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/helpers.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "struct"

// _nonzero tests whether a value is "truthy" (non-zero,
// non-empty, non-null), matching Go text/template semantics.
// A natural candidate for a CUE standard library builtin.
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_test_warnings: "WARNING: There are sections not set. +info https://example.com"
