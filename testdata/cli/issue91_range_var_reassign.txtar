# Variable reassignment inside a range body that captures the range
# element must not leak the range variable outside the for block.
# The converter collects all values via a list comprehension and
# picks the last element, matching Helm's "last value wins" semantics.
# https://github.com/cue-exp/helm2cue/issues/91
exec helm2cue chart input output
cd output
exec cue vet
cd ..
cmp output/helpers.cue expected/helpers.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
{}
-- input/templates/_helpers.tpl --
{{- define "test.join" -}}
{{- $result := "" -}}
{{- range .items -}}
  {{- $result = . -}}
{{- end -}}
{{- $result -}}
{{- end -}}
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  val: {{ include "test.join" (dict "items" (list "a" "b")) }}
-- expected/helpers.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "struct"

// _nonzero tests whether a value is "truthy" (non-zero,
// non-empty, non-null), matching Go text/template semantics.
// A natural candidate for a CUE standard library builtin.
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_test_join: {
	#arg: {
		items?: [...] | {
			...
		}
		...
	}
	{
		let _acc = [
			for _, _range1 in #arg.items {
				_range1
			}]
		[if len(_acc) > 0 {
			_acc[len(_acc)-1]
		}, ""][0]
	}
}
