# List item key-value with inline interpolation should stay inline.
# https://github.com/cue-exp/helm2cue/issues/66
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
replicas: 2
-- chartdir/templates/test.yaml --
items:
{{ range $i, $e := until (.Values.replicas | int) }}
  - spec:
      rules:
        - host: host-{{ $i }}.example.com
          http:
            paths:
              - path: /foo
{{- end -}}
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "list"

test: [{
	items: [
		for _key0, _val0 in list.Range(0, int & #values.replicas, 1) {
			spec: rules: [
				{
					host: "host-\(_key0).example.com"
					http: paths: [
						{
							path: "/foo"
						},
					]
				},
			]
		},
	]
}]
