# Inline if/else value absorbs the next sibling field.
# Regression test for https://github.com/cue-exp/helm2cue/issues/87.
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
useCert: true
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: Pod
spec:
  secret:
    key: {{ if .Values.useCert }}ca.crt{{ else }}ca{{ end }}
    optional: false
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		apiVersion: "v1"
		kind:       "Pod"
		spec: secret: {
			if (_nonzero & {
				#arg: #values.useCert
			}).out {
				key: "ca.crt"
			}
			if !((_nonzero & {
				#arg: #values.useCert
			}).out) {
				key: "ca"
			}
			optional: false
		}
	},
]
