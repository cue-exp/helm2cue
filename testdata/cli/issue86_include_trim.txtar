# Include piped to trim and toYaml piped to b64enc both produce
# type errors because the converter passes a struct where a string
# is expected. The converter should insert yaml.Marshal when a
# non-scalar expression flows into a string-expecting function.
# https://github.com/cue-exp/helm2cue/issues/86
exec helm2cue chart input output
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
config:
  key1: val1
-- input/templates/_helpers.tpl --
{{- define "test.annotations" -}}
foo: bar
{{- end -}}
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  annotations:
    {{- include "test.annotations" . | trim | nindent 4 }}
data:
  config: {{ toYaml .Values.config | b64enc | quote }}
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import (
	"strings"
	"encoding/base64"
)

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name:        "test"
			annotations: strings.TrimSpace(_test_annotations)
		}
		data: config: "\(base64.Encode(null, #values.config))"
	},
]
