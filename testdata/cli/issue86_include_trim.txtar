# toYaml piped to b64enc passes a struct to base64.Encode because
# the converter treats toYaml as a no-op passthrough. The fix inserts
# yaml.Marshal to serialize the struct before encoding.
# https://github.com/cue-exp/helm2cue/issues/86
exec helm2cue chart input output
cd output
exec cue vet
cd ..
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
config:
  key1: val1
-- input/templates/cm.yaml --
apiVersion: v1
kind: Secret
metadata:
  name: test
data:
  config: {{ toYaml .Values.config | b64enc | quote }}
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import (
	"encoding/base64"
	"strings"
	"encoding/yaml"
)

cm: [
	{
		apiVersion: "v1"
		kind:       "Secret"
		metadata: name: "test"
		data: config:   "\(base64.Encode(null, strings.TrimRight(yaml.Marshal(#values.config), "\n")))"
	},
]
