# Struct-valued fields in values.yaml should be typed as _ in the
# schema, not as scalar. A bare struct value like labels: {} conflicts
# with the scalar type.
# https://github.com/cue-exp/helm2cue/issues/51
exec helm2cue chart chartdir outdir
stderr 'values.yaml does not satisfy inferred schema'
stderr 'converted 1/1 templates'
cmp outdir/values.cue expected/values.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
labels: {}
-- chartdir/templates/configmap.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  {{- with .Values.labels }}
  labels:
    {{- range $k, $v := . }}
    {{ $k }}: {{ $v }}
    {{- end }}
  {{- end }}
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

#values: {
	labels?: bool | number | string | null
	...
}
