# Parenthesized optional field access ((.Values.global).kubeVersion)
# should add the chain field as optional in the values schema.
# https://github.com/cue-exp/helm2cue/issues/96
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/cm.cue expected/cm.cue
cmp output/values.cue expected/values.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
global:
  imageRegistry: ""
kubeVersion: ""
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  kube: {{ default (default .Capabilities.KubeVersion.Version .Values.kubeVersion) ((.Values.global).kubeVersion) }}
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: kube: [if (_nonzero & {
			#arg: #values.global.kubeVersion
		}).out {
			#values.global.kubeVersion
		}, [if (_nonzero & {
			#arg: #values.kubeVersion
		}).out {
			#values.kubeVersion
		}, #capabilities.KubeVersion.Version][0]][0]
	},
]
-- expected/values.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

#values: {
	kubeVersion?: bool | number | string | null
	global?: {
		kubeVersion?: bool | number | string | null
		...
	}
	...
}
