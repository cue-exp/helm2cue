# Dict helper variables lose #arg qualification: when a helper
# receives a dict argument and assigns keys to local variables,
# later use of those variables should reference #arg.field, not
# bare field names.
# https://github.com/cue-exp/helm2cue/issues/90
exec helm2cue chart input output
cmp output/deploy.cue expected/deploy.cue
cmp output/helpers.cue expected/helpers.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
{}
-- input/templates/_helpers.tpl --
{{- define "myapp.labels" -}}
{{- $component := default "" .component -}}
app.kubernetes.io/component: {{ $component }}
{{- end -}}
-- input/templates/deploy.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  labels:
    {{- include "myapp.labels" (dict "component" "web") | nindent 4 }}
-- expected/deploy.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

deploy: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name: "test"
			labels: _myapp_labels & {
				#arg: {component: "web"}
				_
			}
		}
	},
]
-- expected/helpers.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "struct"

// _nonzero tests whether a value is "truthy" (non-zero,
// non-empty, non-null), matching Go text/template semantics.
// A natural candidate for a CUE standard library builtin.
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}

_myapp_labels: {
	#arg: {
		component?: bool | number | string | null
		...
	}
	"app.kubernetes.io/component": [if (_nonzero & {
		#arg: #arg.component
		_
	}) {
		#arg.component
	}, ""][0]
}
