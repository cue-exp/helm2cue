Pipeline default with field reference fallback.

-- values.yaml --
primary: hello
fallback: world
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ .Values.primary | default .Values.fallback }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: hello
-- output.cue --
import "struct"

#values: {
	primary?:  bool | number | string | null
	fallback?: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: [if (_nonzero & {#arg: #values.primary}).out {
			#values.primary
		}, #values.fallback][0]
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
