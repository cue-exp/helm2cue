Pipeline with default value that uses printf as fallback.

-- _helpers.tpl --
-- values.yaml --
image:
  tag: "latest"
-- helm_output.yaml --
tag: latest
-- input.yaml --
tag: {{ .Values.image.tag | default (printf "v%s" .Chart.AppVersion) }}
-- output.cue --
import "struct"

#chart: {
	AppVersion?: bool | number | string | null
	...
}
#values: {
	image?: {
		tag?: bool | number | string | null
		...
	}
	...
}

output: [
	{
		tag: "\([if (_nonzero & {
			#arg: #values.image.tag
			_
		}) {
			#values.image.tag
		}, "v\(#chart.AppVersion)"][0])"
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
