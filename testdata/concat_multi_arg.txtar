concat with multiple list arguments in a with condition
-- values.yaml --
global:
  tolerations:
    - key: "global"
      operator: "Exists"
controller:
  tolerations:
    - key: "controller"
      operator: "Exists"
-- input.yaml --
apiVersion: apps/v1
kind: Deployment
metadata:
  name: test
spec:
  template:
    spec:
      {{- with concat .Values.global.tolerations .Values.controller.tolerations }}
      tolerations:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      containers:
        - name: main
          image: test:latest
-- helm_output.yaml --
apiVersion: apps/v1
kind: Deployment
metadata:
  name: test
spec:
  template:
    spec:
      tolerations:
        - key: global
          operator: Exists
        - key: controller
          operator: Exists
      containers:
        - name: main
          image: test:latest
-- output.cue --
import (
	"list"
	"struct"
)

#values: {
	global?: {
		tolerations!: _
		...
	}
	controller?: {
		tolerations!: _
		...
	}
	...
}

output: [
	{
		apiVersion: "apps/v1"
		kind:       "Deployment"
		metadata: name: "test"
		spec: template: spec: {
			if (_nonzero & {#arg: list.Concat([#values.global.tolerations, #values.controller.tolerations])}).out {
				tolerations: list.Concat([#values.global.tolerations, #values.controller.tolerations])
			}
			containers: [
				{
					name:  "main"
					image: "test:latest"
				},
			]
		}
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
