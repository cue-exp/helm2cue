Range with inline text+action interpolation on list items.
Reproduces cue-exp/helm2cue#6: "- --{{ $key }}={{ $value }}" was
previously mishandled because the "=" text node destroyed the frame stack.

-- _helpers.tpl --
-- values.yaml --
extraArgs:
  port: "8080"
  verbose: "true"
-- helm_output.yaml --
spec:
  args:
    - --port=8080
    - --verbose=true
  name: test
-- input.yaml --
spec:
  args:
    {{- range $key, $value := .Values.extraArgs }}
    - --{{ $key }}={{ $value }}
    {{- end }}
  name: test
-- output.cue --
import "struct"

#values: {
	extraArgs?: _
	...
}

output: [
	{
		spec: {
			args: [
				if (_nonzero & {#arg: #values.extraArgs, _}) for _key0, _val0 in #values.extraArgs {
					"--\(_key0)=\(_val0)"
				},
			]
			name: "test"
		}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
