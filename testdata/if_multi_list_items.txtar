Multiple YAML list items inside a conditional block should
each get their own conditional guard in CUE.

-- input.yaml --
apiVersion: v1
kind: Pod
metadata:
  name: test
spec:
  containers:
  - name: test
    args:
    {{- if .Values.tls }}
      - a
      - b
    {{- end }}
-- values.yaml --
tls: true
-- helm_output.yaml --
apiVersion: v1
kind: Pod
metadata:
  name: test
spec:
  containers:
  - name: test
    args:
      - a
      - b
-- output.cue --
import "struct"

#values: {
	tls?: bool | number | string | null
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "Pod"
		metadata: name: "test"
		spec: containers: [
			{
				name: "test"
				args: [if (_nonzero & {#arg: #values.tls, _}) {
					"a"
				}, if (_nonzero & {#arg: #values.tls, _}) {
					"b"
				},
				]
			},
		]
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
