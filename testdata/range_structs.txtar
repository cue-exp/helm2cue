Range over a list of structs, accessing fields.

-- values.yaml --
ports:
  - name: http
    port: 80
  - name: https
    port: 443
-- input.yaml --
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
  {{- range .Values.ports }}
    - name: {{ .name }}
      port: {{ .port }}
  {{- end }}
-- helm_output.yaml --
apiVersion: v1
kind: Service
metadata:
  name: test
spec:
  ports:
    - name: http
      port: 80
    - name: https
      port: 443
-- output.cue --
import "struct"

#values: {
	ports?: [...{
		name!: bool | number | string | null
		port!: bool | number | string | null
		...
	}] | {
		[string]: {
			name!: bool | number | string | null
			port!: bool | number | string | null
			...
		}
	}
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "Service"
		metadata: name: "test"
		spec: ports: [
			if (_nonzero & {#arg: #values.ports}).out
			for _, _range0 in #values.ports {
				name: _range0.name
				port: _range0.port
			},
		]
	},
]
_nonzero: {
	#arg?: _
	out: [if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
