merge function: first argument (destination) wins over source.

-- values.yaml --
defaults:
  color: blue
  size: large
overrides:
  color: red
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  labels: {{ merge .Values.overrides .Values.defaults | toYaml | nindent 4 }}
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
  labels: 
    color: red
    size: large
-- output.cue --
#values: {
	overrides!: _
	defaults!:  _
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: {
			name: "test"
			labels: (_merge & {#a: #values.overrides, #b: #values.defaults}).out
		}
	},
]
_merge: {
	#a!: _
	#b!: _
	out: {
		for k, v in #a {
			(k): v
		}
		for k, v in #b if #a[k] == _|_ {
			(k): v
		}
	}
}
