Helper ranges over #arg.items (passed via dict), propagating list element
field types back to the include call site.

-- values.yaml --
volumes:
  - name: data
    mountPath: /data
-- helpers.tpl --
{{- define "renderVolumes" -}}
{{- range .items }}
- name: {{ .name }}
  mountPath: {{ .mountPath }}
{{- end }}
{{- end -}}
-- input.yaml --
apiVersion: apps/v1
kind: Deployment
spec:
  template:
    spec:
      volumes:
        {{- include "renderVolumes" (dict "items" .Values.volumes) | nindent 8 }}
-- helm_output.yaml --
apiVersion: apps/v1
kind: Deployment
spec:
  template:
    spec:
      volumes:
        
        - name: data
          mountPath: /data
-- output.cue --
import "struct"

#values: {
	volumes!: [...{
		name!:      bool | number | string | null
		mountPath!: bool | number | string | null
		...
	}]
	...
}
_renderVolumes: {
	#arg: {
		items?: [...{
			name!:      bool | number | string | null
			mountPath!: bool | number | string | null
			...
		}]
		...
	}
	let _args = #arg
	[if (_nonzero & {#arg: _args.items, _}) for _, _range1 in _args.items {
		{
			name:      _range1.name
			mountPath: _range1.mountPath
		}
	}]
}

output: [
	{
		apiVersion: "apps/v1"
		kind:       "Deployment"
		spec: template: spec: volumes: _renderVolumes & {#arg: items: #values.volumes, _}
	},
]
_nonzero: {
	#arg?: _
	[if #arg != _|_ {
		[
			if (#arg & int) != _|_ {#arg != 0},
			if (#arg & string) != _|_ {#arg != ""},
			if (#arg & float) != _|_ {#arg != 0.0},
			if (#arg & bool) != _|_ {#arg},
			if (#arg & [...]) != _|_ {len(#arg) > 0},
			if (#arg & {...}) != _|_ {(#arg & struct.MaxFields(0)) == _|_},
			false,
		][0]
	}, false][0]
}
